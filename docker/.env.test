COMPOSE_PROJECT_NAME=pinboard-test

# users ids can be retrieved by the command: id $USER
PUID=1000
PGID=1000

# app
APP_ENV=test
APP_DEBUG=1
TZ=Europe/Moscow

# ports are auto-assigned to avoid conflicts with the dev stack
NGINX_HOST_HTTP_PORT=0
MYSQL_PORT=0
PINBA_UDP_PORT=0

# php
INSTALL_XDEBUG=false

# pinba mysql image published to Docker Hub
PINBA_IMAGE=xolegator/pinba-engine:8.4

# mysql + pinba
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=pinba

# app db credentials used by pinboard
DB_NAME=pinba
DB_USER=pinba
DB_PASSWORD=pinba
DB_SERVER_VERSION=8.4.0
DB_APP_USER=pinba
DB_APP_PASSWORD=pinba

# aggregate service interval (15 min)
AGGREGATE_INTERVAL_SECONDS=900
APP_AGGREGATE_LOCK_TTL_SECONDS=900
