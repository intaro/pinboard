# .env.public.example — copy to .env and fill in the blanks
#
# cp .env.public.example .env
# docker compose -f docker-compose.public.yml up -d

# ── Required: generate with `openssl rand -hex 32` ──────────────────────────
APP_SECRET=CHANGE_ME

# ── Required: database passwords ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# ── Optional: database names (defaults are fine) ─────────────────────────────
MYSQL_DATABASE=pinba
DB_USER=pinba

# ── Optional: port mapping on the host ──────────────────────────────────────
PINBOARD_HTTP_PORT=8080
MYSQL_PORT=13306
PINBA_UDP_PORT=30002

# ── Optional: timezone ───────────────────────────────────────────────────────
TZ=UTC

# ── Optional: mail (null = disabled) ────────────────────────────────────────
MAILER_DSN=null://null

# ── Optional: data retention and aggregation ────────────────────────────────
APP_RECORDS_LIFETIME=P1M
APP_AGGREGATION_PERIOD=PT15M

# ── Optional: alerting thresholds ───────────────────────────────────────────
APP_LOGGING_LONG_REQUEST_TIME_GLOBAL=1.5
APP_LOGGING_HEAVY_REQUEST_GLOBAL=30000
APP_LOGGING_HEAVY_CPU_REQUEST_GLOBAL=1

# ── Optional: email notifications ───────────────────────────────────────────
APP_NOTIFICATION_ENABLE=0
APP_NOTIFICATION_SENDER=noreply@pinboard.local
APP_NOTIFICATION_GLOBAL_EMAIL=
