{% extends "base.html.twig" %}

{% block title %}{{ title }} — {{ parent() }}{% endblock %}
{% block content %}
    {% set is_grouped = grouping is not empty %}
    <h1 class="d-flex flex-wrap align-items-center gap-2">
        <span>Request timers</span>
        {% if grouping_tags|length %}
            <span class="text-muted fs-6">grouped by</span>
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    {{ grouping is empty ? 'none' : grouping }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    {% for t in grouping_tags %}
                        <li>
                            <a class="dropdown-item {{ t == grouping ? 'active' : '' }}" href="{{ path('timers_show', { type: type, requestId: request_id, grouping: 'grouping-' ~ t }) }}">
                                {{ t }}
                            </a>
                        </li>
                    {% endfor %}
                    <li>
                        <a class="dropdown-item {{ not grouping ? 'active' : '' }}" href="{{ path('timers_show', { type: type, requestId: request_id, grouping: 'grouping-none' }) }}">
                            none
                        </a>
                    </li>
                </ul>
            </div>
        {% endif %}
    </h1>
    <hr/>
    <div class="row g-3 align-items-start">
        <div class="col-12 col-lg-10">
            <p class="lead timer">
                <a href="//{{ request.server_name ~ request.script_name }}" title="">
                    {{ request.server_name ~ request.script_name }}
                </a>
                <br/>
                {% for k, v in request.tags %}
                    <span class="text-body-secondary"><small>{{ k }} = {{ v }}{{ not loop.last ? ',' : '' }}</small></span>
                {% endfor %}
            </p>
        </div>
        <div class="col-12 col-lg-2 text-lg-end">
            <p class="lead timer">
                {{ request.req_time_format }} ms<br/>
                {% if request.mem_peak_usage_format is defined %}
                    {{ request.mem_peak_usage_format }} kB<br/>
                {% endif %}
            </p>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            {% if is_grouped %}
                <div id="req-chart" style="height: 150px;"></div>
                <script type="text/javascript">
                    rtChart = null;
                    rtChartData = [{
                        {% for k, v in request.timers %}
                        "{{ k }}": "{{ v.value }}"{{ loop.revindex0 > 0 ? ',' : '' }}
                        {% endfor %}
                        {% if request.req_time_other is defined %}
                        , "other": "{{ request.req_time_other }}"
                        {% endif %}
                    }];

                    AmCharts.ready(function () {
                        // SERIAL CHART
                        rtChart = new AmCharts.AmSerialChart();
                        rtChart.pathToImages = "/js/amcharts/images/";
                        rtChart.dataProvider = rtChartData;
                        rtChart.rotate = true;

                        let categoryAxis = rtChart.categoryAxis;
                        categoryAxis.gridAlpha = 0.02;
                        //categoryAxis.axisColor = "#DADADA";
                        categoryAxis.labelsEnabled = false;

                        // Value
                        let valueAxis = new AmCharts.ValueAxis();
                        valueAxis.gridAlpha = 0.02;
                        valueAxis.stackType = '100%';
                        rtChart.addValueAxis(valueAxis);

                        let graph = new AmCharts.AmGraph();

                        // GRAPH
                        {% for k, v in request.timers %}
                        graph = new AmCharts.AmGraph();
                        graph.type = "column";
                        graph.balloonText = "[[title]]: {{ v.value_percent }}%";
                        graph.valueText = "[[value]] ms";
                        graph.labelText = "[[value]] ms";
                        graph.valueField = "{{ k }}";
                        graph.title = "{{ k }}";
                        graph.lineAlpha = 0.5;
                        graph.fillAlphas = 0.3;
                        rtChart.addGraph(graph);
                        {% endfor %}

                        {% if request.req_time_other_percent is defined %}
                        graph = new AmCharts.AmGraph();
                        graph.type = "column";
                        graph.balloonText = "[[title]]: {{ request.req_time_other_percent }}%";
                        graph.valueText = "[[value]] ms";
                        graph.labelText = "[[value]] ms";
                        graph.valueField = "other";
                        graph.title = "other";
                        graph.lineAlpha = 0.5;
                        graph.fillAlphas = 0.3;
                        rtChart.addGraph(graph);
                        {% endif %}

                        // WRITE
                        rtChart.write("req-chart");
                    });
                </script>
            {% endif %}
        </div>
    </div>
    {% if is_grouped %}
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle timer-table">
                <thead class="table-light">
                <tr>
                    <th scope="col">Timer</th>
                    <th scope="col" class="text-end">Hit count</th>
                    <th scope="col" class="text-end">Value %</th>
                    <th scope="col" class="text-end">Timer value</th>
                </tr>
                </thead>
                <tbody>
                {% for k, v in request.timers %}
                    {% set group_index = loop.index %}
                    <tr class="table-active timer-group-toggle" data-group-index="{{ group_index }}">
                        <td>
                            <button type="button" class="btn btn-link btn-sm p-0 me-2 expand" aria-expanded="true">
                                <i class="bi bi-dash-circle"></i>
                            </button>
                            <strong>{{ k }}</strong>
                        </td>
                        <td class="text-end">{{ v.hit_count }}</td>
                        <td class="text-end">{{ v.value_percent }}%</td>
                        <td class="text-end">{{ v.value_format }} ms</td>
                    </tr>
                    {% for timer in v.timers %}
                        <tr class="timer-group-row timer-group-row-{{ group_index }}">
                            <td>
                                <div class="ps-4">
                                    <small class="text-body-secondary">
                                        {% for tag, tag_value in timer.tags %}
                                            {{ tag ~ ' = ' ~ tag_value }}<br/>
                                        {% else %}
                                            —
                                        {% endfor %}
                                    </small>
                                </div>
                            </td>
                            <td class="text-end">
                                <small>{{ timer.hit_count }}</small>
                            </td>
                            <td class="text-end">
                                <small>{{ timer.value_percent }}%</small>
                            </td>
                            <td class="text-end">
                                <small>{{ timer.value_format }} ms</small>
                            </td>
                        </tr>
                    {% endfor %}
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <hr/>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle timer-table">
                <thead class="table-light">
                <tr>
                    <th scope="col">Timer</th>
                    <th scope="col" class="text-end">Hit count</th>
                    <th scope="col" class="text-end">Value %</th>
                    <th scope="col" class="text-end">Timer value</th>
                </tr>
                </thead>
                <tbody>
                {% for timer in request.timers %}
                    <tr>
                        <td>
                            <small class="text-body-secondary">
                                {% for tag, tag_value in timer.tags %}
                                    {{ tag ~ ' = ' ~ tag_value }}<br/>
                                {% else %}
                                    —
                                {% endfor %}
                            </small>
                        </td>
                        <td class="text-end">
                            <small>{{ timer.hit_count }}</small>
                        </td>
                        <td class="text-end">
                            <small>{{ timer.value_percent }}%</small>
                        </td>
                        <td class="text-end">
                            <small>{{ timer.value_format }} ms</small>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript">
        $('.timer-group-toggle .expand').on('click', function (event) {
            event.preventDefault();

            const toggle = $(this);
            const row = toggle.closest('.timer-group-toggle');
            const groupIndex = row.data('group-index');
            const detailRows = $('.timer-group-row-' + groupIndex);
            const collapsed = detailRows.first().hasClass('d-none');
            const icon = toggle.find('i');

            if (collapsed) {
                detailRows.removeClass('d-none');
                row.addClass('table-active');
                toggle.attr('aria-expanded', 'true');
                icon.removeClass('bi-plus-circle').addClass('bi-dash-circle');
            } else {
                detailRows.addClass('d-none');
                row.removeClass('table-active');
                toggle.attr('aria-expanded', 'false');
                icon.removeClass('bi-dash-circle').addClass('bi-plus-circle');
            }
        });
    </script>
{% endblock %}
