<!DOCTYPE html>
<html lang="en">

<head>
    <title>{% block title %}Intaro Pinboard{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="{{ base_url }}img/favicon.ico" rel="icon" type="image/x-icon"/>
    {#    <link href="{{ base_url }}css/bootstrap.min.css" rel="stylesheet"/> #}
    <script src="{{ base_url }}js/amcharts/amcharts.js" type="text/javascript"></script>
</head>
<body>
<div id="wrap">

    <nav class="navbar navbar-expand-lg navbar-light bg-black">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <img src="{{ base_url }}img/intaropinboard_logo.png"/>
            </a>
            {% include '_menu.html.twig' %}
        </div>
    </nav>
    <div class="{% block body_classes %}container{% endblock %}">
        {% block content %}{% endblock %}
    </div>

    <div id="push"></div>
</div>

<footer class="footer">
    <div class="container">
        <p>Developed by <a href="http://intaro.ru" target="_blank">Intaro</a></p>
        <p>Code and documentation licensed under the MIT license.</p>
    </div>
</footer>

{# {% block javascripts %} #}
{#    <script src="{{ base_url }}js/jquery-3.7.1.min.js" type="text/javascript"></script> #}
{#    <script src="{{ base_url }}js/micro_tpl.js" type="text/javascript"></script> #}
{#    <script src="{{ base_url }}js/bootstrap.min.js" type="text/javascript"></script> #}
{# {% endblock %} #}

{% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block javascripts %}
    <script src="{{ base_url }}js/jquery-3.7.1.min.js" type="text/javascript"></script>
    <script src="{{ base_url }}js/micro_tpl.js" type="text/javascript"></script>
    {{ encore_entry_script_tags('app') }}
{% endblock %}

</body>
</html>
